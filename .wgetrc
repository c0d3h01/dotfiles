user_agent = Mozilla/5.0
referer = auto

continue = on
tries = 20
retry_connrefused = on
waitretry = 1

dns_timeout = 10
connect_timeout = 15
read_timeout = 30

tcp_keepalive = on
prefer-family = IPv4

content_disposition = on
trust_server_names = on
use_server_timestamps = on

check_certificate = on
hsts = on
keep_session_cookies = on
max_redirect = 20

show-progress = on
progress = bar:force:noscroll
verbose = off

robots = off
no_parent = on

server_response = off
